<% if component_settings.try(:display_progress_enabled?) && result.progress.present? %>
  <div class="accountability__progress">

    <div class="text-xs font-normal"><%= display_percentage result.progress %></div>

    <div class="progress-bar" role="progressbar" aria-label="Genomförande" aria-valuenow="<%= number_with_precision(result.progress, separator: ".", precision: 1) %>" aria-valuemin="0" aria-valuemax="100" aria-valuetext="<%= number_to_percentage(result.progress, precision: 1) %>">
      <div style="width:<%= result.progress %>%"></div>
    </div>
  </div>
<% end %>

